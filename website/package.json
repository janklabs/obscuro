    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
